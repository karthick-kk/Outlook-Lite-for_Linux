# Maintainer: ofl <ofl@dev.ofl>
pkgname=ofl
pkgver=1.0.0
pkgrel=1
pkgdesc="Outlook Lite for Linux — lightweight Outlook client using CEF"
arch=('x86_64')
url="https://github.com/karthick-kk/outlook-lite-for-linux"
license=('MIT')
depends=('gtk3' 'libayatana-appindicator' 'libnotify' 'nss')
makedepends=('cmake' 'pkg-config' 'curl' 'patchelf')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/karthick-kk/outlook-lite-for-linux/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

_cef_dir="${srcdir}/cef"

prepare() {
    cd "${srcdir}"
    bash "${pkgname}-${pkgver}/packaging/download-cef.sh" "${_cef_dir}"
}

build() {
    cd "${srcdir}/${pkgname}-${pkgver}"
    mkdir -p build && cd build
    cmake .. -DCMAKE_BUILD_TYPE=Release -DCEF_ROOT="${_cef_dir}"
    make -j$(nproc)
    patchelf --set-rpath '$ORIGIN' ofl
}

package() {
    cd "${srcdir}/${pkgname}-${pkgver}"

    install -Dm755 build/ofl "${pkgdir}/usr/lib/ofl/ofl"

    for lib in libcef.so libEGL.so libGLESv2.so libvk_swiftshader.so libvulkan.so.1; do
        install -Dm755 "${_cef_dir}/Release/${lib}" "${pkgdir}/usr/lib/ofl/${lib}"
    done
    for f in v8_context_snapshot.bin vk_swiftshader_icd.json; do
        install -Dm644 "${_cef_dir}/Release/${f}" "${pkgdir}/usr/lib/ofl/${f}"
    done

    for f in icudtl.dat chrome_100_percent.pak chrome_200_percent.pak resources.pak; do
        install -Dm644 "${_cef_dir}/Resources/${f}" "${pkgdir}/usr/lib/ofl/${f}"
    done
    cp -r "${_cef_dir}/Resources/locales" "${pkgdir}/usr/lib/ofl/"

    install -Dm755 /dev/stdin "${pkgdir}/usr/bin/ofl" <<'EOF'
#!/bin/sh
exec /usr/lib/ofl/ofl "$@"
EOF

    install -Dm644 data/ofl.desktop "${pkgdir}/usr/share/applications/ofl.desktop"
    install -Dm644 data/dev.ofl.outlook-lite.appdata.xml "${pkgdir}/usr/share/metainfo/dev.ofl.outlook-lite.appdata.xml"
    install -Dm644 data/ofl.svg "${pkgdir}/usr/share/icons/hicolor/scalable/apps/ofl.svg"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
