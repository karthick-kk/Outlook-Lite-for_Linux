# Maintainer: ofl <ofl@dev.ofl>
pkgname=ofl
pkgver=1.0.1
pkgrel=1
pkgdesc="Outlook Lite for Linux — lightweight native Outlook client"
arch=('x86_64')
url="https://github.com/karthick-kk/Outlook-Lite-for_Linux"
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3' 'libayatana-appindicator')
makedepends=('rust' 'cargo')
source=()

build() {
    cd "$startdir"
    cargo build --release --manifest-path src-tauri/Cargo.toml
}

package() {
    cd "$startdir"
    install -Dm755 src-tauri/target/release/ofl "${pkgdir}/usr/bin/ofl"
    install -Dm644 data/ofl.desktop "${pkgdir}/usr/share/applications/ofl.desktop"
    install -Dm644 data/ofl.svg "${pkgdir}/usr/share/icons/hicolor/scalable/apps/ofl.svg"
    install -Dm644 data/ofl-app.svg "${pkgdir}/usr/share/icons/hicolor/scalable/apps/ofl-app.svg"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
