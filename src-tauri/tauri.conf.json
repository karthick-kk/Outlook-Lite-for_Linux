{
  "productName": "ofl",
  "version": "1.0.1",
  "identifier": "dev.ofl.outlook-lite",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "resources": [],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ],
        "desktopTemplate": "../data/ofl.desktop",
        "files": {
          "/usr/share/icons/hicolor/scalable/apps/ofl-app.svg": "../data/ofl-app.svg",
          "/usr/share/icons/hicolor/scalable/apps/ofl.svg": "../data/ofl.svg"
        }
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3",
          "libayatana-appindicator-gtk3"
        ]
      }
    }
  }
}
